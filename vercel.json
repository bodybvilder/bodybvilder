{
  "buildCommand": "DISABLE_ESLINT_PLUGIN=true react-scripts build",
  "outputDirectory": "build",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/exercise-gifs/(.*)",
      "dest": "/exercise-gifs/$1",
      "headers": { "cache-control": "public, max-age=604800" }
    },
    {
      "src": "/(icon-192\\.png|icon-512\\.png|manifest\\.json|favicon\\.ico|robots\\.txt|bodybvilder_logo_clean\\.svg)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
