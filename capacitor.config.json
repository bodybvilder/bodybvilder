{
  "appId": "com.bodybvilder.app",
  "appName": "BODYBVILDER",
  "webDir": "build",
  "server": {
    "androidScheme": "https"
  },
  "bundledWebRuntime": false,
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a0f"
    }
  },
  "android": {
    "buildOptions": {
      "keystorePath": "bodybvilder.keystore",
      "keystoreAlias": "bodybvilder"
    }
  }
}